        window.showConfirmModal('Apakah Anda yakin ingin menghapus data barang ini?', () => {
            fetch('/api/barang?slug=' + slug, { method: 'DELETE' })
            .then(res => {
                if(res.ok) {
                    showToast('Barang berhasil dihapus');
