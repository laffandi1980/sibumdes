    const mappingTransaksiForm = document.getElementById('mappingTransaksiForm');
    if(mappingTransaksiForm) {
        mappingTransaksiForm.addEventListener('submit', (e) => {
            e.preventDefault();
            const mappingContext = getCurrentMappingContext();
            const fd = new FormData(mappingTransaksiForm);
            // Explicitly send 0 for unchecked checkbox
            if (!fd.has('link_aset_tetap')) fd.append('link_aset_tetap', '0');
            // Keep legacy fields false by default
            if (!fd.has('link_persediaan')) fd.append('link_persediaan', '0');
            if (!fd.has('link_bk_utang')) fd.append('link_bk_utang', '0');
            if (!fd.has('link_bk_piutang')) fd.append('link_bk_piutang', '0');
            if (!fd.has('link_jurnal_penyesuaian')) fd.append('link_jurnal_penyesuaian', '0');

            const cashType = fd.get('cash_in_out');
            fd.set('kategori_transaksi', cashType === 'kas_keluar' ? 'keluar' : 'masuk');
            const urlEncodedData = new URLSearchParams(fd).toString();
            fetch('/api/mapping-transaksi', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: urlEncodedData
            })
            .then(res => {
                if (res.ok) {
                    showToast('Mapping Transaksi berhasil disimpan! ✅');
                    navigateTo(mappingContext ? mappingContext.routeBase : '/mapping-transaksi');
                } else {
                    res.text().then(t => showToast('Gagal menyimpan: ' + t, true));
                }
            })
            .catch(err => {
                console.error(err);
                showToast('Terjadi kesalahan jaringan.', true);
            });
        });
    }

    // Transaksi History Functions
    function loadTransaksiHistory() {
        const tbody = document.getElementById('transaksi-history-tbody');
        if(!tbody) return;

        const sessionSlug = localStorage.getItem('sibumdes_auth') || '';
        console.log('Loading transaksi history with sessionSlug:', sessionSlug);
        fetch('/api/transaksis?session_slug=' + sessionSlug + '&t=' + new Date().getTime())
            .then(res => {
                console.log('API Response status:', res.status);
                return res.json();
            })
            .then(data => {
                console.log('Transaksi data received:', data);
                renderTransaksiHistoryTable(data || []);
            })
            .catch(err => {
                console.error("Failed to load transaksi history", err);
                const tbody = document.getElementById('transaksi-history-tbody');
                if(tbody) {
                    tbody.innerHTML = `
                        <tr>
                            <td colspan="6" style="padding: 32px; text-align: center; color: var(--text-secondary);">
                                <p>Gagal memuat data transaksi</p>
                            </td>
                        </tr>
                    `;
                }
            });
    }

    function renderTransaksiHistoryTable(transaksi) {
        const tbody = document.getElementById('transaksi-history-tbody');
        if(!tbody) return;

        const isPengembang = !localStorage.getItem('sibumdes_profile_id');
        const thead = tbody.closest('table') ? tbody.closest('table').querySelector('thead tr') : null;
        // Update header: add BUMDes column for developer
        if (thead) {
            const existingBumdesth = thead.querySelector('.th-bumdes');
            if (isPengembang && !existingBumdesth) {
                const th = document.createElement('th');
                th.className = 'th-bumdes';
                th.style.cssText = 'padding: 12px 16px; font-weight: 600; color: var(--text-primary); text-align: center; border-right: 1px solid var(--border); text-transform: uppercase; font-size: 0.85rem;';
                th.textContent = 'BUMDes';
                const aksiTh = thead.lastElementChild;
                thead.insertBefore(th, aksiTh);
            } else if (!isPengembang && existingBumdesth) {
                existingBumdesth.remove();
            }
        }

        const colCount = isPengembang ? 9 : 8;
        if(!transaksi || transaksi.length === 0) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="${colCount}" style="padding: 32px; text-align: center; color: var(--text-secondary);">
                        <i class="fa-solid fa-inbox fa-2x" style="margin-bottom: 12px; opacity: 0.5;"></i>
                        <p>Belum ada data transaksi</p>
                    </td>
                </tr>
            `;
            return;
        }

        let rows = '';
        transaksi.forEach((tx, idx) => {
            const tanggal = tx.tanggal ? new Date(tx.tanggal).toLocaleDateString('id-ID', { year: 'numeric', month: '2-digit', day: '2-digit' }) : '-';
            const nama = tx.nama_pelanggan_pemasok || '-';
            const keterangan = tx.keterangan || '-';
            const deskripsi = tx.deskripsi || '';
            const unit = tx.unit_usaha && tx.unit_usaha.NamaUnitUsaha ? tx.unit_usaha.NamaUnitUsaha : '-';
            const nominal = tx.nominal ? new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(tx.nominal) : '-';
            const tipe = tx.tipe_kas === 'tambah' ? '<span style="background:#d1fae5; color:#065f46; padding:4px 8px; border-radius:4px; font-size:0.85rem; font-weight:500;">Masuk</span>' : '<span style="background:#fee2e2; color:#991b1b; padding:4px 8px; border-radius:4px; font-size:0.85rem; font-weight:500;">Keluar</span>';
            const statusBayar = tx.status_bayar === 'kredit' ? '<span style="background:#fef3c7; color:#92400e; padding:4px 8px; border-radius:4px; font-size:0.85rem; font-weight:500;">Kredit</span>' : '<span style="background:#d1fae5; color:#065f46; padding:4px 8px; border-radius:4px; font-size:0.85rem; font-weight:500;">Tunai</span>';
            const bumdesName = tx.profile_bumdes && tx.profile_bumdes.NamaBUMDes ? tx.profile_bumdes.NamaBUMDes : (tx.profile_bumdes_id ? 'ID:' + tx.profile_bumdes_id : '-');
            const bumdesTd = isPengembang ? `<td style="padding: 12px; text-align: center; font-size: 0.85rem;"><span style="background:#ede9fe;color:#5b21b6;padding:4px 8px;border-radius:4px;font-weight:500;">${bumdesName}</span></td>` : '';

            rows += `
                <tr style="border-bottom: 1px solid var(--border);">
                    <td style="padding: 12px; text-align: center; color: var(--text-secondary); font-size: 0.9rem;">${tanggal}</td>
                    <td style="padding: 12px; color: var(--text-secondary); font-size: 0.9rem;">
                        <div>${keterangan}</div>
                        <div style="margin-top:6px;display:inline-block;background:#eef2ff;color:#3730a3;padding:4px 8px;border-radius:6px;font-size:0.78rem;font-weight:500;">Deskripsi: ${deskripsi || '-'}</div>
                    </td>
                    <td style="padding: 12px; color: var(--text-secondary); font-size: 0.9rem;">${nama}</td>
                    <td style="padding: 12px; text-align: center; color: var(--text-secondary); font-size: 0.9rem;">${unit}</td>
                    <td style="padding: 12px; text-align: right; color: var(--text-primary); font-weight: 600; font-size: 0.9rem;">${nominal}</td>
                    <td style="padding: 12px; text-align: center;">${tipe}</td>
                    <td style="padding: 12px; text-align: center;">${statusBayar}</td>
                    ${bumdesTd}
                    <td style="padding: 12px; text-align: center;">
                        <button type="button" class="action-btn edit" onclick="editTransaksi(${tx.id})" title="Edit Transaksi" style="border: none; background: none; cursor: pointer; color: #0284c7; font-size: 1rem; margin-right: 8px;"><i class="fa-solid fa-pen"></i></button>
                        <button type="button" class="action-btn delete" onclick="deleteTransaksi(${tx.id})" title="Hapus Transaksi" style="border: none; background: none; cursor: pointer; color: #dc2626; font-size: 1rem;"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>
            `;
        });

        tbody.innerHTML = rows;
    }

    function loadTransaksiDataView() {
        const container = document.getElementById('transaksi-table-container');
        if(!container) return;

        container.innerHTML = `<div style="text-align:center; padding: 20px;"><i class="fa-solid fa-spinner fa-spin"></i> Memuat data...</div>`;

        const sessionSlug = localStorage.getItem('sibumdes_auth') || '';
        fetch('/api/transaksis?session_slug=' + sessionSlug + '&t=' + new Date().getTime())
            .then(res => res.json())
            .then(data => {
                renderTransaksiDataTable(data || []);
            })
            .catch(err => {
                console.error("Failed to load transaksi", err);
                container.innerHTML = `<div style="text-align:center; padding:40px; color:var(--text-secondary);">
                    <i class="fa-solid fa-exclamation-circle fa-3x" style="margin-bottom:16px;"></i>
                    <p>Gagal memuat data transaksi</p>
                </div>`;
            });
    }

    function renderTransaksiDataTable(transaksi) {
        const container = document.getElementById('transaksi-table-container');
        if(!container) return;

        console.log('Rendering transaksi data table, count:', transaksi ? transaksi.length : 0);

        if(!transaksi || transaksi.length === 0) {
            container.innerHTML = `<div style="text-align:center; padding:40px; color:var(--text-secondary);">
                <i class="fa-solid fa-wallet fa-3x" style="margin-bottom:16px;"></i>
                <p>Belum ada data transaksi yang terdaftar.</p>
            </div>`;
            return;
        }

        const isPengembang = !localStorage.getItem('sibumdes_profile_id');
        const bumdesTh = isPengembang ? `<th style="padding: 12px; font-weight: 600; color: var(--text-primary); text-align: center; border-right: 1px solid var(--border);">BUMDes</th>` : '';

        let tableHTML = `
            <div style="overflow-x: auto; border: 1px solid var(--border); border-radius: var(--radius-md);">
                <table style="width: 100%; border-collapse: collapse; text-align: left; min-width: 800px;">
                    <thead>
                        <tr style="background-color: #f5f5f5; border-bottom: 2px solid var(--border);">
                            <th style="padding: 12px; font-weight: 600; color: var(--text-primary); text-align: center; border-right: 1px solid var(--border);">Tanggal</th>
                            <th style="padding: 12px; font-weight: 600; color: var(--text-primary); border-right: 1px solid var(--border);">Keterangan</th>
                            <th style="padding: 12px; font-weight: 600; color: var(--text-primary); border-right: 1px solid var(--border);">Nama Cust/Supplier</th>
                            <th style="padding: 12px; font-weight: 600; color: var(--text-primary); text-align: center; border-right: 1px solid var(--border);">Unit Usaha</th>
                            <th style="padding: 12px; font-weight: 600; color: var(--text-primary); text-align: right; border-right: 1px solid var(--border);">Nominal</th>
                            <th style="padding: 12px; font-weight: 600; color: var(--text-primary); text-align: center; border-right: 1px solid var(--border);">Kas Masuk/Keluar</th>
                            <th style="padding: 12px; font-weight: 600; color: var(--text-primary); text-align: center; border-right: 1px solid var(--border);">Tunai/Kredit</th>
                            ${bumdesTh}
                            <th style="padding: 12px; font-weight: 600; color: var(--text-primary); text-align: center;">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
        `;

        transaksi.forEach((tx, idx) => {
            const tanggal = tx.tanggal ? new Date(tx.tanggal).toLocaleDateString('id-ID', { year: 'numeric', month: '2-digit', day: '2-digit' }) : '-';
            const nama = tx.nama_pelanggan_pemasok || '-';
            const keterangan = tx.keterangan || '-';
            const deskripsi = tx.deskripsi || '';
            const unit = tx.unit_usaha && tx.unit_usaha.NamaUnitUsaha ? tx.unit_usaha.NamaUnitUsaha : '-';
            const nominal = tx.nominal ? new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(tx.nominal) : '-';
            const tipe = tx.tipe_kas === 'tambah' ? '<span style="background:#d1fae5; color:#065f46; padding:4px 8px; border-radius:4px; font-size:0.85rem; font-weight:500;">Masuk</span>' : '<span style="background:#fee2e2; color:#991b1b; padding:4px 8px; border-radius:4px; font-size:0.85rem; font-weight:500;">Keluar</span>';
            const statusBayar = tx.status_bayar === 'kredit' ? '<span style="background:#fef3c7; color:#92400e; padding:4px 8px; border-radius:4px; font-size:0.85rem; font-weight:500;">Kredit</span>' : '<span style="background:#d1fae5; color:#065f46; padding:4px 8px; border-radius:4px; font-size:0.85rem; font-weight:500;">Tunai</span>';
            const bumdesName = tx.profile_bumdes && tx.profile_bumdes.NamaBUMDes ? tx.profile_bumdes.NamaBUMDes : (tx.profile_bumdes_id ? 'ID:' + tx.profile_bumdes_id : '-');
            const bumdesTd = isPengembang ? `<td style="padding: 12px; text-align: center; font-size: 0.85rem;"><span style="background:#ede9fe;color:#5b21b6;padding:4px 8px;border-radius:4px;font-weight:500;">${bumdesName}</span></td>` : '';

            tableHTML += `
                <tr style="border-bottom: 1px solid var(--border);">
                    <td style="padding: 12px; text-align: center; color: var(--text-secondary); font-size: 0.9rem;">${tanggal}</td>
                    <td style="padding: 12px; color: var(--text-secondary); font-size: 0.9rem;">
                        <div>${keterangan}</div>
                        <div style="margin-top:6px;display:inline-block;background:#eef2ff;color:#3730a3;padding:4px 8px;border-radius:6px;font-size:0.78rem;font-weight:500;">Deskripsi: ${deskripsi || '-'}</div>
                    </td>
                    <td style="padding: 12px; color: var(--text-secondary); font-size: 0.9rem;">${nama}</td>
                    <td style="padding: 12px; text-align: center; color: var(--text-secondary); font-size: 0.9rem;">${unit}</td>
                    <td style="padding: 12px; text-align: right; color: var(--text-primary); font-weight: 600; font-size: 0.9rem;">${nominal}</td>
                    <td style="padding: 12px; text-align: center;">${tipe}</td>
                    <td style="padding: 12px; text-align: center;">${statusBayar}</td>
                    ${bumdesTd}
                    <td style="padding: 12px; text-align: center;">
                        <button type="button" class="action-btn edit" onclick="editTransaksi(${tx.id})" title="Edit Transaksi"><i class="fa-solid fa-pen"></i></button>
                        <button type="button" class="action-btn delete" onclick="deleteTransaksi(${tx.id})" title="Hapus Transaksi"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>
            `;
        });

        tableHTML += `
                    </tbody>
                </table>
            </div>
        `;

        container.innerHTML = tableHTML;
        console.log('Transaksi data table rendered with', transaksi.length, 'rows');
    }

    function loadJurnalRekapitulasi() {
        const container = document.getElementById('jurnal-rekap-table-container');
        if(!container) return;

        container.innerHTML = `<div style="text-align:center;padding:20px;"><i class="fa-solid fa-spinner fa-spin"></i> Menyusun jurnal rekapitulasi...</div>`;
        const sessionSlug = localStorage.getItem('sibumdes_auth') || '';

        fetch('/api/jurnal-rekapitulasi?session_slug=' + sessionSlug + '&t=' + new Date().getTime())
            .then(res => {
                if (!res.ok) throw new Error('Gagal memuat jurnal rekapitulasi');
                return res.json();
            })
            .then(data => {
                renderJurnalRekapitulasiTable(data || []);
            })
            .catch(err => {
                console.error(err);
                container.innerHTML = `<div style="text-align:center;padding:40px;color:var(--text-secondary);"><i class="fa-solid fa-exclamation-circle fa-3x" style="margin-bottom:16px;"></i><p>Gagal memuat data jurnal rekapitulasi.</p></div>`;
            });
    }

    function renderJurnalRekapitulasiTable(rows) {
        const container = document.getElementById('jurnal-rekap-table-container');
        if(!container) return;

        if(!rows || rows.length === 0) {
            container.innerHTML = `<div style="text-align:center;padding:40px;color:var(--text-secondary);"><i class="fa-solid fa-book fa-3x" style="margin-bottom:16px;"></i><p>Belum ada data jurnal rekapitulasi.</p></div>`;
            return;
        }

        const formatDate = (v) => {
            if(!v) return '-';
            const d = new Date(v);
            if(isNaN(d.getTime())) return v;
            return d.toLocaleDateString('id-ID', { year:'numeric', month:'2-digit', day:'2-digit' });
        };

        const formatCurrency = (n) => {
            const num = Number(n || 0);
            return new Intl.NumberFormat('id-ID', { style:'currency', currency:'IDR', minimumFractionDigits:0 }).format(num);
        };

        const yesNoPill = (flag) => flag
            ? '<span style="display:inline-block;min-width:56px;text-align:center;background:#d1fae5;color:#065f46;padding:4px 10px;border-radius:999px;font-size:0.8rem;font-weight:600;">Ya</span>'
            : '<span style="display:inline-block;min-width:56px;text-align:center;background:#e5e7eb;color:#6b7280;padding:4px 10px;border-radius:999px;font-size:0.8rem;font-weight:600;">-</span>';

        let tableHTML = `
            <div style="overflow-x:auto;border:1px solid var(--border);border-radius:var(--radius-md);">
                <table style="width:100%;border-collapse:collapse;text-align:left;min-width:2000px;">
                    <thead>
                        <tr style="background:#f5f5f5;border-bottom:1px solid var(--border);">
                            <th rowspan="2" style="padding:8px 10px;font-weight:700;border-right:1px solid var(--border);white-space:nowrap;">Tanggal</th>
                            <th rowspan="2" style="padding:8px 10px;font-weight:700;border-right:1px solid var(--border);min-width:230px;">Deskripsi Transaksi<br><span style="font-weight:500;font-size:0.78rem;">(dari Mapping)</span></th>
                            <th rowspan="2" style="padding:8px 10px;font-weight:700;border-right:1px solid var(--border);min-width:260px;">Keterangan</th>
                            <th rowspan="2" style="padding:8px 10px;font-weight:700;border-right:1px solid var(--border);white-space:nowrap;">Nama Cust/Supplier</th>
                            <th rowspan="2" style="padding:8px 10px;font-weight:700;border-right:1px solid var(--border);white-space:nowrap;">Unit Usaha</th>
                            <th rowspan="2" style="padding:8px 10px;font-weight:700;border-right:1px solid var(--border);text-align:right;white-space:nowrap;">Nominal</th>
                            <th rowspan="2" style="padding:8px 10px;font-weight:700;border-right:1px solid var(--border);white-space:nowrap;">Tunai/Kredit</th>
                            <th colspan="4" style="padding:8px 10px;font-weight:700;border-right:1px solid var(--border);text-align:center;">Jurnal</th>
                            <th colspan="4" style="padding:8px 10px;font-weight:700;border-right:1px solid var(--border);text-align:center;">Link Kartu</th>
                            <th colspan="1" style="padding:8px 10px;font-weight:700;text-align:center;">Link Jurnal</th>
                        </tr>
                        <tr style="background:#f5f5f5;border-bottom:2px solid var(--border);">
                            <th style="padding:8px 10px;font-weight:700;border-right:1px solid var(--border);">Debit</th>
                            <th style="padding:8px 10px;font-weight:700;border-right:1px solid var(--border);text-align:right;white-space:nowrap;">Nominal</th>
                            <th style="padding:8px 10px;font-weight:700;border-right:1px solid var(--border);">Kredit</th>
                            <th style="padding:8px 10px;font-weight:700;border-right:1px solid var(--border);text-align:right;white-space:nowrap;">Nominal</th>
                            <th style="padding:8px 10px;font-weight:700;border-right:1px solid var(--border);white-space:nowrap;">Aset Tetap</th>
                            <th style="padding:8px 10px;font-weight:700;border-right:1px solid var(--border);white-space:nowrap;">Persediaan</th>
                            <th style="padding:8px 10px;font-weight:700;border-right:1px solid var(--border);white-space:nowrap;">Bk Utang</th>
                            <th style="padding:8px 10px;font-weight:700;border-right:1px solid var(--border);white-space:nowrap;">Bk Piutang</th>
                            <th style="padding:8px 10px;font-weight:700;white-space:nowrap;">Penyesuaian</th>
                        </tr>
                    </thead>
                    <tbody>
        `;

        rows.forEach(r => {
            const tunaiKreditBadge = (r.tunai_kredit || '').toLowerCase().includes('tunai')
                ? '<span style="display:inline-block;background:#d1fae5;color:#065f46;padding:4px 10px;border-radius:4px;font-size:0.8rem;font-weight:600;white-space:nowrap;">Tunai</span>'
                : '<span style="display:inline-block;background:#fee2e2;color:#991b1b;padding:4px 10px;border-radius:4px;font-size:0.8rem;font-weight:600;white-space:nowrap;">Kredit</span>';

            tableHTML += `
                <tr style="border-bottom:1px solid var(--border);">
                    <td style="padding:8px 10px;border-right:1px solid var(--border);white-space:nowrap;color:var(--text-secondary);">${formatDate(r.tanggal)}</td>
                    <td style="padding:8px 10px;border-right:1px solid var(--border);font-weight:500;color:var(--text-primary);">${r.deskripsi_transaksi || '-'}</td>
                    <td style="padding:8px 10px;border-right:1px solid var(--border);color:var(--text-secondary);">${r.keterangan || '-'}</td>
                    <td style="padding:8px 10px;border-right:1px solid var(--border);color:var(--text-secondary);white-space:nowrap;">${r.nama_cust_supplier || '-'}</td>
                    <td style="padding:8px 10px;border-right:1px solid var(--border);color:var(--text-secondary);white-space:nowrap;">${r.unit_usaha || '-'}</td>
                    <td style="padding:8px 10px;border-right:1px solid var(--border);text-align:right;color:var(--text-primary);font-weight:600;white-space:nowrap;">${formatCurrency(r.nominal)}</td>
                    <td style="padding:8px 10px;border-right:1px solid var(--border);text-align:center;">${tunaiKreditBadge}</td>
                    <td style="padding:8px 10px;border-right:1px solid var(--border);color:var(--text-secondary);white-space:nowrap;">${r.jurnal_debet_akun || '-'}</td>
                    <td style="padding:8px 10px;border-right:1px solid var(--border);text-align:right;color:var(--text-primary);font-weight:600;white-space:nowrap;background:#e6f4f1;">${formatCurrency(r.jurnal_debet_nominal)}</td>
                    <td style="padding:8px 10px;border-right:1px solid var(--border);color:var(--text-secondary);white-space:nowrap;">${r.jurnal_kredit_akun || '-'}</td>
                    <td style="padding:8px 10px;border-right:1px solid var(--border);text-align:right;color:var(--text-primary);font-weight:600;white-space:nowrap;">${formatCurrency(r.jurnal_kredit_nominal)}</td>
                    <td style="padding:8px 10px;border-right:1px solid var(--border);text-align:center;">${yesNoPill(!!r.link_aset_tetap)}</td>
                    <td style="padding:8px 10px;border-right:1px solid var(--border);text-align:center;">${yesNoPill(!!r.link_persediaan)}</td>
                    <td style="padding:8px 10px;border-right:1px solid var(--border);text-align:center;">${yesNoPill(!!r.link_bk_utang)}</td>
                    <td style="padding:8px 10px;border-right:1px solid var(--border);text-align:center;">${yesNoPill(!!r.link_bk_piutang)}</td>
                    <td style="padding:8px 10px;text-align:center;">${yesNoPill(!!r.link_jurnal_penyesuaian)}</td>
                </tr>
            `;
        });

        tableHTML += `
                    </tbody>
                </table>
            </div>
        `;

        container.innerHTML = tableHTML;
    }

    // ─── Mapping Transaksi CRUD ──────────────────────────────────────────────

    function loadMappingTransaksi() {
        const container = document.getElementById('mapping-transaksi-table-container');
        if (!container) return;
        container.innerHTML = `<div style="text-align:center;padding:20px;"><i class="fa-solid fa-spinner fa-spin"></i> Memuat data...</div>`;
        const sessionSlug = localStorage.getItem('sibumdes_auth') || '';
        const mappingContext = applyMappingContextToView();
        const jenisMapping = mappingContext ? mappingContext.apiValue : 'harian';
        fetch('/api/mapping-transaksis?session_slug=' + sessionSlug + '&jenis_mapping=' + encodeURIComponent(jenisMapping) + '&t=' + new Date().getTime())
            .then(res => res.json())
            .then(data => renderMappingTransaksiTable(data || []))
            .catch(() => {
                container.innerHTML = `<div style="text-align:center;padding:40px;color:var(--text-secondary);"><i class="fa-solid fa-exclamation-circle fa-3x" style="margin-bottom:16px;"></i><p>Gagal memuat data mapping transaksi.</p></div>`;
            });
    }

    function renderMappingTransaksiTable(items) {
        const container = document.getElementById('mapping-transaksi-table-container');
        if (!container) return;

        if (!items || items.length === 0) {
            container.innerHTML = `<div style="text-align:center;padding:40px;color:var(--text-secondary);">
                <i class="fa-solid fa-link fa-3x" style="margin-bottom:16px;"></i>
                <p>Belum ada data mapping transaksi terdaftar.</p>
            </div>`;
            return;
        }

        const renderLinkCheckbox = (checked) => `
            <input type="checkbox" ${checked ? 'checked' : ''} disabled style="width:16px;height:16px;accent-color:var(--primary);pointer-events:none;">
        `;

        let tableHTML = `
            <div style="overflow-x:auto;border:1px solid var(--border);border-radius:var(--radius-md);">
                <table style="width:100%;border-collapse:collapse;text-align:left;min-width:1550px;">
                    <thead>
                        <tr style="background:#f5f5f5;border-bottom:1px solid var(--border);">
                            <th rowspan="2" style="padding:10px 12px;font-weight:700;color:var(--text-primary);white-space:nowrap;border-right:1px solid var(--border);">No</th>
                            <th rowspan="2" style="padding:10px 12px;font-weight:700;color:var(--text-primary);white-space:nowrap;border-right:1px solid var(--border);">Unit Usaha</th>
                            <th rowspan="2" style="padding:10px 12px;font-weight:700;color:var(--text-primary);min-width:220px;border-right:1px solid var(--border);">Deskripsi</th>
                            <th rowspan="2" style="padding:10px 12px;font-weight:700;color:var(--text-primary);min-width:210px;border-right:1px solid var(--border);">Debit</th>
                            <th rowspan="2" style="padding:10px 12px;font-weight:700;color:var(--text-primary);min-width:260px;border-right:1px solid var(--border);">Kredit</th>
                            <th colspan="4" style="padding:10px 12px;font-weight:700;color:var(--text-primary);text-align:center;border-right:1px solid var(--border);">LINK BUKU PEMBANTU</th>
                            <th rowspan="2" style="padding:10px 12px;font-weight:700;color:var(--text-primary);min-width:150px;border-right:1px solid var(--border);">Klasifikasi</th>
                            <th rowspan="2" style="padding:10px 12px;font-weight:700;color:var(--text-primary);min-width:130px;border-right:1px solid var(--border);">Cash In/Out</th>
                            <th rowspan="2" style="padding:10px 12px;font-weight:700;color:var(--text-primary);min-width:190px;border-right:1px solid var(--border);">Kategori Arus Kas</th>
                            <th rowspan="2" style="padding:10px 12px;font-weight:700;color:var(--text-primary);text-align:center;white-space:nowrap;">Aksi</th>
                        </tr>
                        <tr style="background:#f5f5f5;border-bottom:2px solid var(--border);">
                            <th style="padding:8px 10px;font-weight:700;color:var(--text-primary);text-align:center;white-space:nowrap;border-right:1px solid var(--border);">BP Utang</th>
                            <th style="padding:8px 10px;font-weight:700;color:var(--text-primary);text-align:center;white-space:nowrap;border-right:1px solid var(--border);">BP Piutang</th>
                            <th style="padding:8px 10px;font-weight:700;color:var(--text-primary);text-align:center;white-space:nowrap;border-right:1px solid var(--border);">Kartu Persediaan</th>
                            <th style="padding:8px 10px;font-weight:700;color:var(--text-primary);text-align:center;white-space:nowrap;border-right:1px solid var(--border);">Kartu Aset Tetap (Inventaris)</th>
                        </tr>
                    </thead>
                    <tbody>`;

        items.forEach((m, idx) => {
            const mappingContext = getCurrentMappingContext();
            const editPath = mappingContext ? `${mappingContext.routeBase}/edit/${m.slug}` : `/mapping-transaksi/edit/${m.slug}`;
            const unit = m.unit_usaha ? m.unit_usaha.NamaUnitUsaha : '-';
            const cashType = m.cash_in_out === 'kas_keluar'
                ? '<span style="display:inline-block;white-space:nowrap;background:#fee2e2;color:#991b1b;padding:4px 10px;border-radius:4px;font-size:0.8rem;font-weight:600;">Kas Keluar</span>'
                : '<span style="display:inline-block;white-space:nowrap;background:#d1fae5;color:#065f46;padding:4px 10px;border-radius:4px;font-size:0.8rem;font-weight:600;">Kas Masuk</span>';
            tableHTML += `
                <tr style="border-bottom:1px solid var(--border);">
                    <td style="padding:10px 12px;color:var(--text-secondary);border-right:1px solid var(--border);">${idx + 1}</td>
                    <td style="padding:10px 12px;color:var(--text-secondary);border-right:1px solid var(--border);white-space:nowrap;">${unit}</td>
                    <td style="padding:10px 12px;font-weight:500;color:var(--text-primary);border-right:1px solid var(--border);">${m.nama_mapping || '-'}</td>
                    <td style="padding:10px 12px;color:var(--text-secondary);border-right:1px solid var(--border);white-space:nowrap;">${m.akun_debet || '-'}</td>
                    <td style="padding:10px 12px;color:var(--text-secondary);border-right:1px solid var(--border);white-space:nowrap;">${m.akun_kredit || '-'}</td>
                    <td style="padding:10px 12px;text-align:center;border-right:1px solid var(--border);">${renderLinkCheckbox(!!m.link_bk_utang)}</td>
                    <td style="padding:10px 12px;text-align:center;border-right:1px solid var(--border);">${renderLinkCheckbox(!!m.link_bk_piutang)}</td>
                    <td style="padding:10px 12px;text-align:center;border-right:1px solid var(--border);">${renderLinkCheckbox(!!m.link_persediaan)}</td>
                    <td style="padding:10px 12px;text-align:center;border-right:1px solid var(--border);">${renderLinkCheckbox(!!m.link_aset_tetap)}</td>
                    <td style="padding:10px 12px;color:var(--text-secondary);border-right:1px solid var(--border);">${m.klasifikasi_arus_kas || '-'}</td>
                    <td style="padding:10px 12px;white-space:nowrap;border-right:1px solid var(--border);">${cashType}</td>
                    <td style="padding:10px 12px;color:var(--text-secondary);border-right:1px solid var(--border);">${m.kategori_arus_kas || '-'}</td>
                    <td style="padding:12px;text-align:center;">
                        <button type="button" class="action-btn edit" title="Edit" onclick="navigateTo('${editPath}')"><i class="fa-solid fa-pen"></i></button>
                        <button type="button" class="action-btn delete" title="Hapus" onclick="deleteMappingTransaksi('${m.slug}')"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>`;
        });

        tableHTML += `</tbody></table></div>`;
        container.innerHTML = tableHTML;
    }

    function editMappingTransaksiData(slug) {
        const mappingContext = getCurrentMappingContext();
        const jenisMapping = mappingContext ? mappingContext.apiValue : 'harian';
        fetch('/api/mapping-transaksi?slug=' + encodeURIComponent(slug) + '&jenis_mapping=' + encodeURIComponent(jenisMapping))
            .then(res => res.json())
            .then(data => {
                if (!data || !data.id) { navigateTo(mappingContext ? mappingContext.routeBase : '/mapping-transaksi'); return; }
                document.getElementById('mapping_transaksi_slug').value = data.slug || '';
                document.getElementById('mapping_nama').value = data.nama_mapping || '';
                document.getElementById('mapping_klasifikasi_arus_kas').value = data.klasifikasi_arus_kas || '';
                document.getElementById('mapping_cash_in_out').value = data.cash_in_out || '';
                document.getElementById('mapping_kategori_arus_kas').value = data.kategori_arus_kas || '';
                document.getElementById('mapping_akun_debet').value = data.akun_debet || '';
                document.getElementById('mapping_akun_kredit').value = data.akun_kredit || '';
                document.getElementById('mapping_tipe_default').value = data.tipe_default || 'semua';
                document.getElementById('mapping_keterangan').value = data.keterangan || '';
                document.getElementById('mapping_link_aset_tetap').checked = !!data.link_aset_tetap;
                document.getElementById('mapping_link_persediaan').checked = !!data.link_persediaan;
                document.getElementById('mapping_link_bk_utang').checked = !!data.link_bk_utang;
                document.getElementById('mapping_link_bk_piutang').checked = !!data.link_bk_piutang;
                // Set unit usaha after dropdown loads
                const setUnit = () => {
                    const sel = document.getElementById('mapping_unit_usaha_id');
                    if (sel && data.unit_usaha_id) sel.value = data.unit_usaha_id;
                };
                setTimeout(setUnit, 500);
            })
            .catch(() => { showToast('Gagal memuat data mapping.', true); navigateTo(mappingContext ? mappingContext.routeBase : '/mapping-transaksi'); });
    }

    window.deleteMappingTransaksi = function(slug) {
        window.showConfirmModal('Yakin ingin menghapus mapping transaksi ini?', function() {
            const mappingContext = getCurrentMappingContext();
            const jenisMapping = mappingContext ? mappingContext.apiValue : 'harian';
            fetch('/api/mapping-transaksi?slug=' + encodeURIComponent(slug) + '&jenis_mapping=' + encodeURIComponent(jenisMapping), { method: 'DELETE' })
                .then(res => {
                    if (res.ok) {
                        showToast('Mapping transaksi berhasil dihapus');
                        loadMappingTransaksi();
                    } else {
                        res.text().then(t => showToast('Gagal menghapus: ' + t, true));
                    }
                })
                .catch(err => showToast('Kesalahan jaringan: ' + err.message, true));
        });
    };

    window.deleteTransaksi = function(id) {
        window.showConfirmModal('Yakin ingin menghapus transaksi ini?', function() {
            fetch('/api/transaksi?id=' + id, { method: 'DELETE' })
                .then(res => {
                    if (res.ok) {
                        showToast('Transaksi berhasil dihapus');
                        loadTransaksiHistory();
                        loadTransaksiDataView();
                    } else {
                        res.text().then(t => showToast('Gagal menghapus: ' + t, true));
                    }
                })
                .catch(err => showToast('Kesalahan jaringan: ' + err.message, true));
        });
    };

    window.editTransaksi = function(id) {
        const sessionSlug = localStorage.getItem('sibumdes_auth') || '';
        fetch('/api/transaksis?session_slug=' + sessionSlug)
            .then(res => res.json())
            .then(data => {
                const tx = (data || []).find(t => t.id === id);
                if (!tx) { showToast('Data tidak ditemukan', true); return; }
                openEditTransaksiModal(tx);
            })
            .catch(err => showToast('Gagal memuat data: ' + err.message, true));
    };

    function openEditTransaksiModal(tx) {
        const existing = document.getElementById('edit-transaksi-modal');
        if (existing) existing.remove();

        const tanggal = tx.tanggal ? tx.tanggal.split('T')[0] : '';
        const modal = document.createElement('div');
        modal.id = 'edit-transaksi-modal';
        modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:9999;display:flex;align-items:center;justify-content:center;padding:16px;overflow-y:auto;';
        modal.innerHTML = `
            <div style="background:#fff;border-radius:12px;padding:32px;width:100%;max-width:900px;box-shadow:0 12px 40px rgba(0,0,0,0.18);">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
                    <h3 style="margin:0;font-size:1.3rem;color:var(--text-primary);">Edit Transaksi</h3>
                    <button id="edit-tx-close" type="button" style="background:none;border:none;font-size:1.4rem;cursor:pointer;color:var(--text-secondary);">&times;</button>
                </div>
                <div style="overflow-x:auto;border:1px solid var(--border);border-radius:8px;margin-bottom:20px;">
                    <table style="width:100%;border-collapse:collapse;text-align:left;min-width:600px;">
                        <thead>
                            <tr style="background-color:#f0f4f0;border-bottom:2px solid var(--border);">
                                <th style="padding:12px 16px;font-weight:700;color:var(--text-primary);text-transform:uppercase;font-size:0.85rem;width:14%;">Tanggal</th>
                                <th style="padding:12px 16px;font-weight:700;color:var(--text-primary);text-transform:uppercase;font-size:0.85rem;width:36%;">Nama Pelanggan/Pemasok</th>
                                <th style="padding:12px 16px;font-weight:700;color:var(--text-primary);text-transform:uppercase;font-size:0.85rem;width:42%;">Keterangan</th>
                                <th style="padding:12px 16px;font-weight:700;color:var(--text-primary);text-transform:uppercase;font-size:0.85rem;width:8%;text-align:center;">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr data-row-type="main" style="background-color:#f9faf9;border-bottom:1px solid var(--border);">
                                <td style="padding:12px 16px;border-right:1px solid var(--border);">
                                    <input id="edit-tx-tanggal" type="date" value="${tanggal}" style="width:100%;border:1px solid #ddd;background:#ffffff;padding:6px 8px;border-radius:4px;font-weight:500;font-size:0.9rem;" required>
                                </td>
                                <td style="padding:12px 16px;border-right:1px solid var(--border);">
                                    <select id="edit-tx-nama" style="width:100%;background:#ffffff;border:1px solid #ddd;border-radius:6px;padding:8px 12px;font-size:0.9rem;" required>
                                        <option value="">Memuat data...</option>
                                    </select>
                                </td>
                                <td style="padding:12px 16px;border-right:1px solid var(--border);position:relative;">
                                    <input id="edit-tx-keterangan" type="text" value="${tx.keterangan || ''}" style="width:100%;border:1px solid #ddd;background:#ffffff;padding:6px 8px;border-radius:4px;font-size:0.9rem;" required>
                                    <span id="edit-tx-ai-loading" style="display:none;position:absolute;right:20px;top:50%;transform:translateY(-50%);font-size:0.75rem;color:var(--primary);"><i class="fa-solid fa-spinner fa-spin"></i></span>
                                </td>
                                <td style="padding:12px 16px;text-align:center;">
                                    <button id="edit-tx-delete" type="button" style="border:none;background:none;cursor:pointer;color:#999;font-size:1.2rem;title:Hapus;" title="Hapus"><i class="fa-solid fa-trash"></i></button>
                                </td>
                            </tr>
                            <tr data-row-type="detail" style="background:#f7fbff;border-bottom:1px solid var(--border);">
                                <td colspan="4" style="padding:10px 16px 12px 16px;border-top:none;">
                                    <div style="display:grid;grid-template-columns:1.7fr 0.8fr 0.7fr;gap:10px;align-items:end;">
                                        <div>
                                            <div style="font-size:0.74rem;font-weight:600;letter-spacing:0.3px;color:#1d4ed8;margin-bottom:4px;">Deskripsi</div>
                                            <input id="edit-tx-deskripsi" type="text" value="${tx.deskripsi || ''}" style="width:100%;border:1px solid #c7d2fe;background:#eef2ff;padding:7px 10px;border-radius:6px;font-size:0.86rem;color:#3730a3;">
                                        </div>
                                        <div>
                                            <div style="font-size:0.74rem;font-weight:600;letter-spacing:0.3px;color:var(--text-secondary);margin-bottom:4px;">Nominal</div>
                                            <input id="edit-tx-nominal" type="number" value="${tx.nominal || 0}" style="width:100%;border:1px solid #ddd;background:#ffffff;padding:7px 10px;border-radius:6px;text-align:right;font-weight:500;font-size:0.86rem;" required>
                                        </div>
                                        <div>
                                            <div style="font-size:0.74rem;font-weight:600;letter-spacing:0.3px;color:var(--text-secondary);margin-bottom:4px;">Tunai/Kredit</div>
                                            <select id="edit-tx-tipe" style="width:100%;background:#ffffff;border:1px solid #ddd;border-radius:6px;padding:7px 8px;font-weight:500;font-size:0.86rem;text-align:center;cursor:pointer;" required>
                                                <option value="">-</option>
                                                <option value="tambah" ${tx.tipe_kas === 'tambah' ? 'selected' : ''}>Tunai</option>
                                                <option value="kurang" ${tx.tipe_kas === 'kurang' ? 'selected' : ''}>Kredit</option>
                                            </select>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div style="display:flex;gap:10px;justify-content:flex-end;">
                    <button id="edit-tx-cancel" type="button" style="padding:10px 24px;border:1px solid var(--border);border-radius:6px;background:#fff;cursor:pointer;font-size:0.9rem;font-weight:500;">Batal</button>
                    <button id="edit-tx-save" type="button" style="padding:10px 24px;border:none;border-radius:6px;background:var(--primary);color:#fff;cursor:pointer;font-size:0.9rem;font-weight:600;">Simpan Perubahan</button>
                </div>
            </div>
        `;
        document.body.appendChild(modal);

        // Fetch pelanggan list and populate select
        const sessionSlug = localStorage.getItem('sibumdes_auth') || '';
        fetch('/api/pelanggans?session_slug=' + sessionSlug)
            .then(res => res.json())
            .then(pelanggans => {
                const sel = document.getElementById('edit-tx-nama');
                if (!sel) return;
                sel.innerHTML = '<option value="">-- Pilih Pelanggan/Pemasok --</option>';
                (pelanggans || []).forEach(p => {
                    const opt = document.createElement('option');
                    opt.value = p.nama_pelanggan;
                    opt.textContent = p.nama_pelanggan;
                    if (p.nama_pelanggan === tx.nama_pelanggan_pemasok) opt.selected = true;
                    sel.appendChild(opt);
                });
            })
            .catch(() => {
                const sel = document.getElementById('edit-tx-nama');
                if (sel) sel.innerHTML = `<option value="${tx.nama_pelanggan_pemasok || ''}" selected>${tx.nama_pelanggan_pemasok || '-'}</option>`;
            });

        const closeModal = () => modal.remove();
        document.getElementById('edit-tx-cancel').onclick = closeModal;
        document.getElementById('edit-tx-close').onclick = closeModal;
        modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });

        // AI autofill for keterangan input in modal
        let aiDebounceTimer = null;
        const keteranganInput = document.getElementById('edit-tx-keterangan');
        keteranganInput.addEventListener('input', function() {
            const keterangan = this.value.trim();

            if (aiDebounceTimer) clearTimeout(aiDebounceTimer);

            if (!keterangan) {
                const deskripsiInput = document.getElementById('edit-tx-deskripsi');
                if (deskripsiInput) deskripsiInput.value = '';
                return;
            }

            aiDebounceTimer = setTimeout(async () => {
                const deskripsiInput = document.getElementById('edit-tx-deskripsi');
                const nominalInput = document.getElementById('edit-tx-nominal');
                const tipeKasSelect = document.getElementById('edit-tx-tipe');
           const loadingEl = document.getElementById('edit-tx-ai-loading');

           if (loadingEl) loadingEl.style.display = 'inline';
                try {
                    const sessionSlug = localStorage.getItem('sibumdes_auth') || '';
                    console.log('[AI Modal] Requesting suggest for keterangan:', keterangan);
                    
                    const res = await fetch('/api/ai/suggest-transaksi', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ keterangan: keterangan, session_slug: sessionSlug })
                    });

                    console.log('[AI Modal] Response status:', res.status);

                    if (!res.ok) {
                        const errText = await res.text();
                        console.error('[AI Modal] Error response:', errText);
                        return;
                    }

                    const data = await res.json();
                    console.log('[AI Modal] Response data:', data);

                    if (data.deskripsi) {
                        if (deskripsiInput) deskripsiInput.value = data.deskripsi;
                        console.log('[AI Modal] Set deskripsi:', data.deskripsi);
                    }
                    if (data.nominal && data.nominal > 0) {
                        if (nominalInput) nominalInput.value = data.nominal;
                        console.log('[AI Modal] Set nominal:', data.nominal);
                    }
                    if (data.tipe_kas) {
                        if (tipeKasSelect) tipeKasSelect.value = data.tipe_kas;
                        console.log('[AI Modal] Set tipe_kas:', data.tipe_kas);
                    }
                } catch (err) {
                    console.error('[AI Modal] Error:', err.message);
                }
            }, 900);
        });

        document.getElementById('edit-tx-delete').onclick = function() {
            showConfirmModal('Hapus transaksi ini secara permanen?', () => {
                fetch('/api/transaksi?id=' + tx.id, { method: 'DELETE' })
                    .then(res => {
                        if (res.ok) {
                            modal.remove();
                            showToast('Transaksi berhasil dihapus');
                            loadTransaksiHistory();
                            loadTransaksiDataView();
                        } else {
                            res.text().then(t => showToast('Gagal menghapus: ' + t, true));
                        }
                    })
                    .catch(err => showToast('Kesalahan jaringan: ' + err.message, true));
            });
        };

        document.getElementById('edit-tx-save').onclick = function() {
            const payload = {
                tanggal: document.getElementById('edit-tx-tanggal').value,
                nama_pelanggan_pemasok: document.getElementById('edit-tx-nama').value,
                keterangan: document.getElementById('edit-tx-keterangan').value,
                deskripsi: document.getElementById('edit-tx-deskripsi').value,
                nominal: parseFloat(document.getElementById('edit-tx-nominal').value) || 0,
                tipe_kas: document.getElementById('edit-tx-tipe').value,
            };

            if (!payload.tanggal || !payload.nama_pelanggan_pemasok || !payload.keterangan || isNaN(payload.nominal) || payload.nominal <= 0 || !payload.tipe_kas) {
                showToast('Semua field harus diisi dengan benar', true);
                return;
            }

            fetch('/api/transaksi?id=' + tx.id, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(res => {
                if (res.ok) {
                    modal.remove();
                    showToast('Transaksi berhasil diperbarui');
                    loadTransaksiHistory();
                    loadTransaksiDataView();
                } else {
                    res.text().then(t => showToast('Gagal menyimpan: ' + t, true));
                }
            })
            .catch(err => showToast('Kesalahan jaringan: ' + err.message, true));
        };
    }

});
